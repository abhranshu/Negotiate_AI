# ─────────────────────────────────────────────────
# NegotiateAI — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# Database (SQLite by default — change to PostgreSQL for production)
DATABASE_URL=sqlite:///./negotiateai.db
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/negotiateai

# JWT Secret (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-in-production

# Anthropic API key (required for Module 4 LLM moderator and Module 5 LLM enhancement)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20
